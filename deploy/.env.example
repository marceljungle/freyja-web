# Copy to deploy/.env and adjust before running the production stack.

# Database
POSTGRES_DB=freyja
POSTGRES_USER=freyja
POSTGRES_PASSWORD=change-me-please

# JWT signing secret (Base64, >= 256 bits). Generate with:
#   openssl rand -base64 48
FREYJA_JWT_SECRET=change-me-to-a-long-random-base64-secret

# Published host ports
FRONTEND_PORT=8088
MQTT_PORT=1883

# CORS: the browser calls /api same-origin via Nginx, so this is usually just
# the frontend origin. Adjust if you serve the SPA from another host.
FREYJA_CORS_ALLOWED_ORIGINS=http://localhost:8088
